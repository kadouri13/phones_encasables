{
  "name": "boxfinder",
  "version": "1.0.0",
  "description": "BoxFinder Protection Glass Search Utility",
  "main": "backend/server.js",
  "scripts": {
    "install:all": "npm install && npm install --prefix frontend",
    "build": "npm run build --prefix frontend",
    "start": "cross-env NODE_ENV=production node backend/server.js",
    "dev": "concurrently \"nodemon backend/server.js\" \"npm run dev --prefix frontend\"",
    "seed": "node backend/seed.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "nodemon": "^3.1.4"
  }
}
